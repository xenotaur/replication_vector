#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

run_step() {
  echo
  echo "==> $*"
  "$@"
}

run_step "$ROOT/scripts/version" tools
run_step "$ROOT/scripts/format" --check --diff
run_step "$ROOT/scripts/lint"
run_step "$ROOT/scripts/test"
run_step "$ROOT/scripts/baseline"
