#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
WEB_DIR="$ROOT/replication_vector/web"
VELUMIN_DIR="$ROOT/.deps/velumin"

print_version() {
  local label="$1"
  shift

  printf '%-14s ' "$label"
  if "$@" 2>/dev/null; then
    return 0
  fi
  echo "not available"
}

print_velumin() {
  printf '%-14s ' "velumin"
  if [[ -d "$VELUMIN_DIR/.git" ]]; then
    git -C "$VELUMIN_DIR" rev-parse --short HEAD
  else
    echo "not available"
  fi
}

print_version "rustc" rustc --version
print_version "cargo" cargo --version
print_version "rustfmt" rustfmt --version
print_version "clippy" cargo clippy --version
print_version "wasm-pack" wasm-pack --version
print_version "node" node --version
print_version "npm" npm --version
print_version "vite" npm --prefix "$WEB_DIR" exec vite -- --version
print_velumin
