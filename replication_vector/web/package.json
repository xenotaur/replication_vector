{
  "name": "replication-vector-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check:wasm": "cargo check --manifest-path ../Cargo.toml --target wasm32-unknown-unknown",
    "build:wasm": "wasm-pack build .. --target web",
